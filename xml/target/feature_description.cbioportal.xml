<?xml version="1.0" encoding="UTF-8"?>
<!--
  Extended cohort / feature description keyed to cBioPortal Summary tab (study ccrcc_irc_2014).
  Validated 2026-04-18 against public API:
    GET /api/studies/ccrcc_irc_2014/patients  -> 10 patients
    GET /api/studies/ccrcc_irc_2014/samples  -> 79 samples
    Sample lists: "All samples" 79, "Samples with mutation data" 78 -> 78/79 ≈ 98.7% with mutation data
  Source of truth for cohort/features. Generate the legacy file for the static site with:
    python3 code/transform_cbioportal_feature_xml.py
  then: python3 code/build_site/xml2html.py -u target
-->
<feature_description xmlns="http://maids.persimune.dk/schema">

  <dataset_id>ccrcc_irc_2014</dataset_id>
  <dataset_name>Kidney Renal Clear Cell Carcinoma (IRC, Nat Genet 2014)</dataset_name>
  <description>Multi-region whole-exome sequencing of 10 clear cell renal cell carcinomas (ccRCC). 79 tumor regions + matched normal samples. Gerlinger et al., Nature Genetics 2014.</description>

  <!-- === OVERALL COHORT METRICS (aligned with cBioPortal Summary tab / sample lists) === -->
  <cohort_metrics>
    <total_patients>10</total_patients>
    <total_samples>79</total_samples>
    <mutation_frequency>98.7%</mutation_frequency>
    <profiled_samples>78</profiled_samples>
    <comment>Patient and sample counts match /api/studies/ccrcc_irc_2014 patients (10) and samples (79). Mutation coverage 78/79 ≈ 98.7%. Distribution charts (sex, Fuhrman, stage, genes) should be re-verified in the live portal if precision beyond Summary snapshots is required.</comment>
  </cohort_metrics>

  <!-- === SUBSETS === -->
  <subsets>
    <subset id="cohort_overview" name="Cohort Overview" description="High-level dataset metrics from cBioPortal Summary tab"/>
    <subset id="clinical" name="Clinical Data" description="Patient-level clinical variables"/>
    <subset id="sample_annotation" name="Sample Annotation" description="Per-sample region and somatic information"/>
    <subset id="genomic" name="Genomic Features" description="Mutation status and burden metrics"/>
  </subsets>

  <!-- === FEATURES (Summary-tab style; percentages from collaborator agent — confirm in portal) === -->

  <feature id="total_patients">
    <name>Total Patients</name>
    <subset>cohort_overview</subset>
    <type>integer</type>
    <description>Number of patients in the study</description>
    <value>10</value>
    <role>metadata</role>
  </feature>

  <feature id="total_samples">
    <name>Total Samples</name>
    <subset>cohort_overview</subset>
    <type>integer</type>
    <description>Number of tumor regions + matched normals sequenced (all samples list)</description>
    <value>79</value>
    <role>metadata</role>
  </feature>

  <feature id="samples_per_patient">
    <name>Number of Samples per Patient</name>
    <subset>cohort_overview</subset>
    <type>categorical</type>
    <values>4 (10%), 6 (10%), 7 (20%), 8 (30%), 10 (20%), 11 (10%)</values>
    <description>Distribution of samples across the 10 patients (per cBioPortal Summary chart — verify live)</description>
    <role>metadata</role>
  </feature>

  <feature id="sex">
    <name>Sex</name>
    <subset>clinical</subset>
    <type>categorical</type>
    <values>Male (70.0%), Female (30.0%)</values>
    <description>Patient sex distribution (cBioPortal Summary tab)</description>
    <role>feature</role>
    <statistics>Male: 7 patients, Female: 3 patients</statistics>
    <missing_rate>0%</missing_rate>
  </feature>

  <feature id="fuhrman_grade">
    <name>Fuhrman Grade</name>
    <subset>clinical</subset>
    <type>categorical</type>
    <values>1 (8.9%), 1-2 (7.6%), 1-3 (31.6%), 1-4 (27.8%), 2-3 (22.8%), NA (1.3%)</values>
    <description>Histological nuclear grade (cBioPortal Summary tab)</description>
    <role>feature</role>
    <missing_rate>1.3%</missing_rate>
  </feature>

  <feature id="stage">
    <name>Overall Stage</name>
    <subset>clinical</subset>
    <type>categorical</type>
    <values>II (20.0%), IV (80.0%)</values>
    <description>Disease stage (AJCC) at patient level (cBioPortal Summary tab)</description>
    <role>feature</role>
    <missing_rate>0%</missing_rate>
  </feature>

  <feature id="somatic_status">
    <name>Somatic Status</name>
    <subset>sample_annotation</subset>
    <type>categorical</type>
    <values>Matched (96.2%), Unmatched (3.8%)</values>
    <description>Whether sample has matched normal tissue</description>
    <role>feature</role>
    <missing_rate>0%</missing_rate>
  </feature>

  <feature id="tumor_site">
    <name>Tumor Disease Anatomic Site</name>
    <subset>sample_annotation</subset>
    <type>categorical</type>
    <values>Primary tumor regions + specific metastases (Lymph Node, Chest Wall, Perinephric, Renal Vein, etc.)</values>
    <description>Anatomic location of sampled region (most are primary; metastases are rare)</description>
    <role>feature</role>
    <missing_rate>91.1%</missing_rate>
  </feature>

  <feature id="vhl_mutation">
    <name>VHL Mutation Status</name>
    <subset>genomic</subset>
    <type>categorical</type>
    <values>Mutated (79.5%)</values>
    <description>Most recurrent driver gene in ccRCC</description>
    <role>feature</role>
    <statistics>62 mutations in 78 profiled samples (79.5%)</statistics>
  </feature>

  <feature id="pbrm1_mutation">
    <name>PBRM1 Mutation Status</name>
    <subset>genomic</subset>
    <type>categorical</type>
    <values>Mutated (37.2%)</values>
    <role>feature</role>
    <statistics>31 mutations (37.2%)</statistics>
  </feature>

  <feature id="setd2_mutation">
    <name>SETD2 Mutation Status</name>
    <subset>genomic</subset>
    <type>categorical</type>
    <values>Mutated (26.9%)</values>
    <role>feature</role>
    <statistics>23 mutations (26.9%)</statistics>
  </feature>

  <feature id="bap1_mutation">
    <name>BAP1 Mutation Status</name>
    <subset>genomic</subset>
    <type>categorical</type>
    <values>Mutated (24.4%)</values>
    <role>feature</role>
    <statistics>20 mutations (24.4%)</statistics>
  </feature>

  <feature id="patient_id">
    <name>Patient ID</name>
    <subset>cohort_overview</subset>
    <type>string</type>
    <description>Unique patient identifier (10 patients total)</description>
    <role>identifier</role>
  </feature>

  <feature id="sample_id">
    <name>Sample ID</name>
    <subset>sample_annotation</subset>
    <type>string</type>
    <description>Unique sample/region identifier (e.g., EV001_R1, EV005_M1)</description>
    <role>identifier</role>
  </feature>

</feature_description>
